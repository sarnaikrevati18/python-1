    {
      "cell_type": "code",
      "source": [
        "# Create a list\n",
        "fruits = [\"apple\", \"banana\", \"mango\", \"grape\", \"orange\"]\n",
        "\n",
        "# Indexing\n",
        "print(fruits[0])\n",
        "print(fruits[2])\n",
        "\n",
        "# Negative indexing\n",
        "print(fruits[-1])\n",
        "print(fruits[-3])\n",
        "\n",
        "# Slicing\n",
        "print(fruits[1:4])\n",
        "print(fruits[:3])\n",
        "print(fruits[2:])"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
