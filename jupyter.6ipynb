    {
      "cell_type": "code",
      "source": [
        "# Create a list\n",
        "nums = [1, 2, 3, 4]\n",
        "\n",
        "# Update\n",
        "nums[1] = 20\n",
        "print(nums)\n",
        "\n",
        "# Append\n",
        "nums.append(5)\n",
        "print(nums)\n",
        "\n",
        "# Insert\n",
        "nums.insert(2, 15)\n",
        "print(nums)\n",
        "\n",
        "# Delete\n",
        "nums.remove(3)\n",
        "print(nums)\n",
        "\n",
        "del nums[0]\n",
        "print(nums)"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
