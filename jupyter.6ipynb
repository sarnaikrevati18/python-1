    {
      "cell_type": "code",
      "source": [
        "# Create lists\n",
        "list1 = [1, 2, 3]\n",
        "list2 = [4, 5]\n",
        "\n",
        "# Concatenation\n",
        "print(list1 + list2)\n",
        "\n",
        "# Repetition\n",
        "print(list1 * 2)\n",
        "\n",
        "# Length\n",
        "print(len(list1))\n",
        "\n",
        "# Maximum\n",
        "print(max(list1))\n",
        "\n",
        "# Minimum\n",
        "print(min(list1))"
      ],
      "metadata": {
