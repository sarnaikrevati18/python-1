    {
      "cell_type": "code",
      "source": [
        "# Create a list\n",
        "numbers = [10, 20, 30, 40, 50]\n",
        "\n",
        "# Check membership\n",
        "print(20 in numbers)      # True\n",
        "print(60 not in numbers)  # True"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
